# Copy this file to .env and paste any free/trial API keys you want to use.
# The app calls every configured provider and blends the results into one answer.

PORT=5177

# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Groq Console: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Hugging Face tokens: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=openai/gpt-oss-120b:cerebras

# Cohere dashboard: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
COHERE_MODEL=command-a-plus-05-2026

# Cerebras Cloud: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b
